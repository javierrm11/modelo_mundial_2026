# ============================================
# CONFIGURACIÓN DEL MODELO
# ============================================

# Reproducibilidad
RANDOM_SEED=42

# Ventana temporal de entrenamiento (ciclo mundialista 2022→2026)
TRAIN_START_DATE=2022-01-01
TRAIN_END_DATE=2026-06-10

# Ponderación de partidos en el entrenamiento
FRIENDLY_WEIGHT=0.3
COMPETITIVE_WEIGHT=1.0

# Elo dinámico
ELO_INITIAL=1500
ELO_K_FACTOR=60
ELO_HOME_ADVANTAGE=65

# Simulación Monte Carlo
MONTE_CARLO_SIMS=10000
EXTRA_TIME_GOAL_MULTIPLIER=0.5

# ============================================
# RUTAS DEL PROYECTO
# ============================================

DATA_RAW_DIR=./data/raw
DATA_INTERIM_DIR=./data/interim
DATA_PROCESSED_DIR=./data/processed
MODELS_DIR=./outputs/models
PREDICTIONS_DIR=./outputs/predictions
FIGURES_DIR=./outputs/figures

# ============================================
# API KEYS
# ============================================

# Kaggle API — obtener en https://www.kaggle.com/settings → API → Create New Token
KAGGLE_USERNAME=javierruizmolero
KAGGLE_KEY=KGAT_908c3e9d25761aa0c0124cb90ec33b8a

# Football-Data.org — gratis con registro en https://www.football-data.org/client/register
# La usaríamos si quisiéramos calendario oficial vía API en vez de scraping
FOOTBALL_DATA_API_KEY=

# RapidAPI — por si añades API-Football más adelante
RAPIDAPI_KEY=

# ============================================
# CONFIGURACIÓN DE EJECUCIÓN
# ============================================

# Nivel de logs: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Número de cores para LightGBM (-1 = todos)
N_JOBS=-1